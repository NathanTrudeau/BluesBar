<Window x:Class="BluesBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        Width="900"
        Height="650"
        ResizeMode="NoResize"
        Background="Transparent"
        FocusManager.FocusedElement="{Binding RelativeSource={RelativeSource Self}}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Easing functions for smooth UI animation -->
        <CubicEase x:Key="EaseOut" EasingMode="EaseOut"/>
        <CubicEase x:Key="EaseInOut" EasingMode="EaseInOut"/>
        <QuadraticEase x:Key="EaseIn" EasingMode="EaseIn"/>
        <QuadraticEase x:Key="EaseOutQuad" EasingMode="EaseOut"/>

        <Style x:Key="ImageButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root" RenderTransformOrigin="0.5,0.5">

                            <!-- IMPORTANT: named transform directly on Root -->
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="PulseScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <!-- glow (only visible on hover) -->
                            <Border x:Name="Glow" Opacity="0" CornerRadius="20">
                                <Border.Effect>
                                    <DropShadowEffect Color="White" BlurRadius="40" ShadowDepth="0" Opacity="0.95"/>
                                </Border.Effect>
                            </Border>

                            <ContentPresenter HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"/>
                        </Grid>

                        <ControlTemplate.Resources>

                            <!-- Idle pulse -->
                            <Storyboard x:Key="IdlePulse" RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         From="1" To="1.035"
                                         Duration="0:0:2.8">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         From="1" To="1.035"
                                         Duration="0:0:2.8">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>

                                <DoubleAnimation Storyboard.TargetName="Root"
                                         Storyboard.TargetProperty="Opacity"
                                         From="1" To="0.965"
                                         Duration="0:0:2.8">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseInOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>

                            <!-- Hover scale (quick ease) -->
                            <Storyboard x:Key="HoverScaleIn">
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.08"
                                         Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.08"
                                         Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>

                            <!-- Press scale -->
                            <Storyboard x:Key="PressScale">
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1.02"
                                         Duration="0:0:0.06"/>
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1.02"
                                         Duration="0:0:0.06"/>
                                <DoubleAnimation Storyboard.TargetName="Root"
                                         Storyboard.TargetProperty="Opacity"
                                         To="0.85"
                                         Duration="0:0:0.06"/>
                            </Storyboard>

                            <!-- Reset back to 1 (used when leaving hover/press) -->
                            <Storyboard x:Key="ResetScale">
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         To="1"
                                         Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="PulseScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         To="1"
                                         Duration="0:0:0.12">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="Root"
                                         Storyboard.TargetProperty="Opacity"
                                         To="1"
                                         Duration="0:0:0.12"/>
                            </Storyboard>

                        </ControlTemplate.Resources>

                        <ControlTemplate.Triggers>

                            <!-- Start pulsing by default -->
                            <Trigger Property="IsEnabled" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="PulseStoryboard" Storyboard="{StaticResource IdlePulse}"/>
                                </Trigger.EnterActions>
                            </Trigger>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                </Trigger.EnterActions>
                                <Setter TargetName="Glow" Property="Opacity" Value="1"/>
                                <Setter TargetName="Root" Property="Opacity" Value="1"/>

                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource ResetScale}"/>
                                    <BeginStoryboard x:Name="PulseStoryboard2" Storyboard="{StaticResource IdlePulse}"/>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- Press -->
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource PressScale}"/>
                                </Trigger.EnterActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>




        <!-- Unified Button Style (same as AimTrain) -->
        <Style TargetType="Button" x:Key="FancyButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#333"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="BorderBrush" Value="#77BFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#555"/>
                                <Setter Property="BorderBrush" Value="#66A1FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#222"/>
                                <Setter Property="Foreground" Value="#888"/>
                                <Setter Property="BorderBrush" Value="#444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Big Room Tile Button Style -->
        <Style TargetType="Button" x:Key="RoomTileButton">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="BorderBrush" Value="#FF4169E1"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <Grid Margin="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#FF63B8FF"/>
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#333"/>
                                <Setter Property="BorderBrush" Value="#77BFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Root frame: background image + readability overlay + your UI -->
    <Grid>

        <!-- Optional readability tint -->
        <Rectangle Fill="#3A000000" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- CUSTOM TITLE BAR -->
            <DockPanel Grid.Row="0" Background="#1C1C1C" MouseDown="TitleBar_MouseDown">

                <TextBlock Text="BluesBar"
                           FontFamily="Segoe UI Black"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="RoyalBlue"
                           VerticalAlignment="Center"
                           Margin="10,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- Window buttons -->
                <Button Width="32" Height="24" DockPanel.Dock="Right" Content="✕" ToolTip="Close" Foreground="RoyalBlue" Background="White" Click="CloseButton_Click"/>
                <Button Width="32" Height="24" DockPanel.Dock="Right" Content="⬜" ToolTip="Maximize / Restore" Foreground="RoyalBlue" Background="White" Click="MaxRestoreButton_Click"/>
                <Button Width="33" Height="24" DockPanel.Dock="Right" Content="—" ToolTip="Minimize" Foreground="RoyalBlue" Background="White" Click="MinimizeButton_Click"/>

                <DockPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#444"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#555"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DockPanel.Resources>

            </DockPanel>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="1" Background="#0B0F16" ClipToBounds="True">

                    <!-- This Viewbox scales EVERYTHING (image + button overlay) uniformly -->
                    <Viewbox Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     SnapsToDevicePixels="True"
                     UseLayoutRounding="True">

                        <!-- This is the "native" coordinate space: EXACT PNG size -->
                        <Grid Width="1536" Height="1024">

                            <!-- Background PNG -->
                            <Image Source="/Assets/MainMenu.png"
                               Width="1536" Height="1024"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                            <!-- Overlay coordinates match the PNG exactly -->
                            <Canvas Width="1536" Height="1024">


                                <Button Content="+100K" Width="30" Height="51" FontSize="10" Style="{StaticResource FancyButton}" Click="DebugEarn_Click" BorderThickness="4,4,4,4" Background="#FF00F3FF" BorderBrush="#FF001FFF" Opacity="0.9" FontWeight="UltraBlack" Canvas.Left="996" Canvas.Top="509" VerticalAlignment="Top"/>

                                <!-- AIM -->
                                <Button Click="OpenAim_Click"
                                Canvas.Left="26"
                                Canvas.Top="206"
                                Width="334"
                                Height="332"
                                Background="Transparent"
                                BorderThickness="0"
                                Style="{StaticResource ImageButtonStyle}"
                                Cursor="Hand">
                                    <Image Source="/Assets/aim.png"
                                    Stretch="Uniform" Margin="38,32,35,28"/>
                                </Button>


                                <!-- GAMBLOO -->
                                <Button Click="OpenGambloo_Click"
                                    Canvas.Left="1176"
                                    Canvas.Top="185"
                                    Width="360"
                                    Height="339"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource ImageButtonStyle}"
                                    Cursor="Hand">

                                    <Image Source="/Assets/gambloo.png"
                                        Stretch="Uniform" Margin="-22,10,-48,64"/>
                                </Button>


                                <!-- BACKPACK -->
                                <Button Click="OpenBackpack_Click"
                                    Canvas.Left="263"
                                    Canvas.Top="421"
                                    Width="250"
                                    Height="182"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource ImageButtonStyle}"
                                    Cursor="Hand">

                                    <Image Source="/Assets/backpack.png"
                                     Stretch="Uniform" Margin="5,-9,-19,-9"/>
                                </Button>


                                <!-- STORE -->
                                <Button Click="OpenStore_Click"
                                    Canvas.Left="1026"
                                    Canvas.Top="427"
                                    Width="234"
                                    Height="223"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Style="{StaticResource ImageButtonStyle}"
                                    Cursor="Hand">

                                    <Image Source="/Assets/store.png"
                                    Stretch="Uniform" Margin="-14,-16,-14,-17"/>
                                </Button>


                                <!-- Bottom (PROFILE HUD) -->
                                <Button x:Name="QuickProfileButton"
                                    Click="OpenProfileManager_Click"
                                    Canvas.Left="608"
                                    Canvas.Top="717"
                                    Width="333"
                                    Height="182"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Top">

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid x:Name="Root">

                                                <!-- Idle aura behind the card -->
                                                <Border x:Name="Aura"
                                                    CornerRadius="18"
                                                    Opacity="0.35"
                                                    Margin="-6"
                                                    Background="RoyalBlue">
                                                    <Border.Effect>
                                                        <DropShadowEffect x:Name="AuraShadow"
                                                          Color="GhostWhite"
                                                          BlurRadius="62"
                                                          ShadowDepth="0"
                                                          Opacity="0.95"/>
                                                    </Border.Effect>
                                                </Border>
                                                <Border CornerRadius="18"
                                                    Margin="-2"
                                                    BorderThickness="3"
                                                    BorderBrush="#0B0F16"
                                                    Opacity="0.35"/>

                                                <!-- Your card (unchanged look) -->
                                                <Border x:Name="Card"
                                                    Background="#FF6FC3E2"
                                                    BorderBrush="Black"
                                                    BorderThickness="4"
                                                    CornerRadius="16"
                                                    Padding="18"
                                                    SnapsToDevicePixels="True">

                                                    <Border.Effect>
                                                        <DropShadowEffect Color="Black"
                                                          BlurRadius="14"
                                                          ShadowDepth="0"
                                                          Opacity="0.7"/>
                                                    </Border.Effect>

                                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch"
                                                      SnapsToDevicePixels="True"/>
                                                </Border>

                                            </Grid>

                                            <ControlTemplate.Resources>

                                                <!-- Idle aura "breathing" (opacity only) -->
                                                <Storyboard x:Key="IdleAura" RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="Aura"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.22" To="0.42"
                                                         Duration="0:0:2.8">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>

                                                    <!-- tiny blur change so it feels alive, not flickery -->
                                                    <DoubleAnimation Storyboard.TargetName="AuraShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         From="24" To="34"
                                                         Duration="0:0:2.8">
                                                        <DoubleAnimation.EasingFunction>
                                                            <CubicEase EasingMode="EaseInOut"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>

                                                <!-- Hover aura (stronger) -->
                                                <Storyboard x:Key="HoverAuraIn">
                                                    <DoubleAnimation Storyboard.TargetName="Aura"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.62"
                                                         Duration="0:0:0.12"/>
                                                    <DoubleAnimation Storyboard.TargetName="AuraShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="42"
                                                         Duration="0:0:0.12"/>
                                                    <DoubleAnimation Storyboard.TargetName="Card"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.97"
                                                         Duration="0:0:0.12"/>
                                                </Storyboard>

                                                <!-- Reset aura -->
                                                <Storyboard x:Key="HoverAuraOut">
                                                    <DoubleAnimation Storyboard.TargetName="Aura"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.35"
                                                         Duration="0:0:0.12"/>
                                                    <DoubleAnimation Storyboard.TargetName="AuraShadow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="28"
                                                         Duration="0:0:0.12"/>
                                                    <DoubleAnimation Storyboard.TargetName="Card"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.12"/>
                                                </Storyboard>

                                                <!-- Press -->
                                                <Storyboard x:Key="PressDown">
                                                    <DoubleAnimation Storyboard.TargetName="Card"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.90"
                                                         Duration="0:0:0.05"/>
                                                    <DoubleAnimation Storyboard.TargetName="Aura"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.25"
                                                         Duration="0:0:0.05"/>
                                                </Storyboard>

                                            </ControlTemplate.Resources>

                                            <ControlTemplate.Triggers>

                                                <!-- Start idle aura -->
                                                <Trigger Property="IsEnabled" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard x:Name="IdleAuraStoryboard"
                                                            Storyboard="{StaticResource IdleAura}"/>
                                                    </Trigger.EnterActions>
                                                </Trigger>

                                                <!-- Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard Storyboard="{StaticResource HoverAuraIn}"/>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard Storyboard="{StaticResource HoverAuraOut}"/>
                                                    </Trigger.ExitActions>
                                                </Trigger>

                                                <!-- Press -->
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard Storyboard="{StaticResource PressDown}"/>
                                                    </Trigger.EnterActions>
                                                </Trigger>

                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>



                                    <!-- ✅ CONTENT goes AFTER Button.Template -->
                                    <StackPanel>
                                        <TextBlock Text="PROFILE"
                                           FontSize="16"
                                           FontFamily="Segoe UI Black"/>
                                        <TextBlock x:Name="LevelLineText"
                                           Text="Lv 1"
                                           Foreground="#1F2933"
                                           FontSize="18"
                                           FontFamily="Segoe UI Black"
                                           Margin="0,4,0,2"
                                           Opacity="0.95"/>
                                        <TextBlock x:Name="PlayerNameText"
                                           FontSize="32"
                                           FontFamily="Segoe UI Black"/>

                                        <TextBlock x:Name="SavingsText"
                                            FontSize="30"/>

                                        <TextBlock x:Name="NetWorthText"
                                            FontSize="22"/>
                                    </StackPanel>

                                </Button>



                            </Canvas>
                        </Grid>
                    </Viewbox>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>

