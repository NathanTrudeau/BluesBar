<Window x:Class="BluesBar.ProfileManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile"
        Width="680"
        Height="600"
        WindowStartupLocation="CenterOwner"
        Background="#0B0F16"
        ResizeMode="NoResize">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="PROFILE MANAGER"
                       Foreground="White"
                       FontFamily="Segoe UI Black"
                       FontSize="22"/>
            <TextBlock Text="Edit your display name and color. Full totals shown here."
                       Foreground="#A9B4C0"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Card -->
        <Border Grid.Row="1"
                Background="#121A26"
                BorderBrush="#263248"
                BorderThickness="2"
                CornerRadius="16"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Preview -->
                <Border Background="#0F1520"
                        BorderBrush="#233049"
                        BorderThickness="2"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,0,0,10">

                    <StackPanel>
                        <TextBlock Text="Preview"
                                   Foreground="#A9B4C0"
                                   FontSize="12"
                                   FontFamily="Segoe UI Semibold"/>
                        <TextBlock x:Name="LevelFullText"
                                   Text="Lv 1"
                                   FontSize="18"
                                   FontFamily="Segoe UI Black"
                                   Foreground="White"
                                   Margin="0,6,0,0"/>
                        <TextBlock x:Name="PendingLevelsText"
                                   Text=""
                                   FontSize="10"
                                   FontFamily="Segoe UI Semibold"
                                   Foreground="#B0B0B0"
                                   Margin="0,2,0,0"/>
                        <TextBlock x:Name="PreviewNameText"
                                   Text="Player"
                                   FontFamily="Segoe UI Black"
                                   FontSize="34"
                                   Margin="0,6,0,0"/>

                    </StackPanel>
                </Border>

                <!-- Username -->
                <StackPanel Grid.Row="1" Margin="0,0,0,14">
                    <TextBlock Text="Username"
                               Foreground="White"
                               FontFamily="Segoe UI Semibold"
                               FontSize="12"/>
                    <TextBox x:Name="UsernameBox"
                             Height="34"
                             FontSize="14"
                             Margin="0,6,0,0"
                             Padding="10,6"
                             Background="#0F1520"
                             Foreground="White"
                             BorderBrush="#2A3952"
                             BorderThickness="2"
                             TextChanged="UsernameBox_TextChanged"/>
                    <TextBlock x:Name="UsernameErrorText"
                               Foreground="#FF6B6B"
                               FontSize="12"
                               Visibility="Collapsed"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Color Swatches -->
                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <TextBlock Text="Username Color"
                               Foreground="White"
                               FontFamily="Segoe UI Semibold"
                               FontSize="12"/>

                    <WrapPanel Margin="0,8,0,0">

                        <!-- P1 -->
                        <Button Click="ColorPick_Click" Tag="#FFCFE8FF"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFCFE8FF"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P2 -->
                        <Button Click="ColorPick_Click" Tag="#FFD8FFE9"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFD8FFE9"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P3 -->
                        <Button Click="ColorPick_Click" Tag="#FFE7D8FF"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFE7D8FF"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P4 -->
                        <Button Click="ColorPick_Click" Tag="#FFFFF0C9"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFFFF0C9"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P5 -->
                        <Button Click="ColorPick_Click" Tag="#FF00C2FF"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FF00C2FF"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P6 -->
                        <Button Click="ColorPick_Click" Tag="#FF00E676"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FF00E676"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P7 -->
                        <Button Click="ColorPick_Click" Tag="#FF483DFF"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FF483DFF"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P8 -->
                        <Button Click="ColorPick_Click" Tag="#FFB400FF"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFB400FF"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P9 -->
                        <Button Click="ColorPick_Click" Tag="#FFFF2E4D"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFFF2E4D"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                        <!-- P10 -->
                        <Button Click="ColorPick_Click" Tag="#FFFFD700"
                            Margin="0,0,8,8" Width="34" Height="34"
                            Padding="0" Background="#FFFFD700"
                            BorderBrush="#203040" BorderThickness="2" Cursor="Hand"/>

                    </WrapPanel>

                </StackPanel>

                <!-- Full Values -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#0F1520" CornerRadius="12" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="COINS"
                                       Foreground="#A9B4C0"
                                       FontSize="12"
                                       FontFamily="Segoe UI Semibold"/>
                            <TextBlock x:Name="CoinsFullText"
                                   Foreground="Gold"
                                   FontSize="16"
                                   FontFamily="Segoe UI Black"
                                   Margin="0,6,0,0"
                                   TextWrapping="NoWrap"
                                   TextTrimming="None"
                                   HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#0F1520" CornerRadius="12" Padding="12">
                        <StackPanel>
                            <TextBlock Text="NET WORTH"
                                       Foreground="#A9B4C0"
                                       FontSize="12"
                                       FontFamily="Segoe UI Semibold"/>
                            <TextBlock x:Name="NetWorthFullText"
                                       Foreground="LightGoldenrodYellow"
                                       FontSize="16"
                                       FontFamily="Segoe UI Black"
                                       Margin="0,6,0,0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="None"
                                       HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Border>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="110" Height="34" Margin="0,0,10,0" Click="Cancel_Click"
                    Background="#1B2433" Foreground="White" BorderBrush="#2A3952" BorderThickness="2">
                Cancel
            </Button>
            <Button Width="140" Height="34" Click="Save_Click"
                    Background="#2F5BFF" Foreground="White" BorderBrush="#6FA0FF" BorderThickness="2">
                Save Profile
            </Button>
        </StackPanel>
    </Grid>
</Window>

