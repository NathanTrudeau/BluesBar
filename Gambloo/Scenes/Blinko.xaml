<UserControl x:Class="BluesBar.Gambloo.Scenes.BlinkoScene"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B0F16"
             Width="860" Height="520"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>
        <!-- BluePack / BluesBar theme -->
        <SolidColorBrush x:Key="Panel" Color="#111827"/>
        <SolidColorBrush x:Key="Panel2" Color="#0E1A2F"/>
        <SolidColorBrush x:Key="Stroke" Color="#22324A"/>
        <SolidColorBrush x:Key="Accent" Color="#6FC3E2"/>
        <SolidColorBrush x:Key="TextDim" Color="#9AA3B2"/>

        <Style TargetType="Button" x:Key="NeoButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Background" Value="#1F2A40"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#25324C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource NeoButton}">
            <Setter Property="Background" Value="#0B6B3A"/>
            <Setter Property="BorderBrush" Value="#3FA34D"/>
            <Setter Property="FontFamily" Value="Segoe UI Black"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="LabelDim">
            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="TextBox" x:Key="NeoBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="NeoCombo">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="34"/>
        </Style>

        <Style TargetType="ToggleButton" x:Key="NeoToggle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#182235"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1F2A40"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource Panel}"
                BorderBrush="{StaticResource Stroke}"
                BorderThickness="2"
                CornerRadius="16"
                Padding="12"
                Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Blinko" Foreground="White" FontFamily="Segoe UI Black" FontSize="18"/>
                    <TextBlock x:Name="WalletText" Text="Savings: 0 Coins" Foreground="{StaticResource TextDim}" FontSize="12"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="LastWinText" Text="" Foreground="Gold" FontFamily="Consolas" FontSize="13" Margin="0,0,14,0"/>
                    <TextBlock x:Name="FpsText" Text="FPS: --" Foreground="{StaticResource Accent}" FontFamily="Consolas" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Border Grid.Row="1"
                Background="{StaticResource Panel2}"
                BorderBrush="{StaticResource Stroke}"
                BorderThickness="2"
                CornerRadius="16"
                Padding="12">

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Left control panel -->
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="12"/>
                    <!-- Board -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left panel -->
                <Border Grid.Column="0"
                        Background="{StaticResource Panel}"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="2"
                        CornerRadius="14"
                        Padding="12">
                    <StackPanel>

                        <!-- Manual / Auto -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="ManualToggle"
                                          Grid.Column="0"
                                          Style="{StaticResource NeoToggle}"
                                          Content="Manual"
                                          IsChecked="True"
                                          Checked="Manual_Checked"/>

                            <ToggleButton x:Name="AutoToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource NeoToggle}"
                                          Content="Auto"
                                          Margin="10,0,0,0"
                                          Checked="Auto_Checked"
                                          Unchecked="Auto_Unchecked"/>
                        </Grid>

                        <TextBlock Text="Amount" Style="{StaticResource LabelDim}"/>
                        <Grid Margin="0,6,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="86"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="BetBox" Grid.Column="0" Style="{StaticResource NeoBox}" Text="100"/>
                            <Border Grid.Column="1"
                                    BorderBrush="{StaticResource Stroke}"
                                    BorderThickness="2"
                                    CornerRadius="10"
                                    Background="#0B1220"
                                    Padding="10,6"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Coins"
                                           Foreground="{StaticResource Accent}"
                                           FontFamily="Segoe UI Black"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Style="{StaticResource NeoButton}" Content="+1K" Click="Plus1k_Click" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Style="{StaticResource NeoButton}" Content="1/2" Click="Half_Click" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Style="{StaticResource NeoButton}" Content="2x" Click="Double_Click"/>
                        </Grid>

                        <TextBlock Text="Risk" Style="{StaticResource LabelDim}"/>
                        <ComboBox x:Name="RiskCombo" Style="{StaticResource NeoCombo}" Margin="0,6,0,14" SelectionChanged="Risk_Changed">
                            <ComboBoxItem Content="Low"/>
                            <ComboBoxItem Content="Medium" IsSelected="True"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>

                        <Button x:Name="PlayButton"
                                Style="{StaticResource PrimaryButton}"
                                Content="Play"
                                Height="44"
                                Click="Drop_Click"/>

                        <Button x:Name="ClearButton"
                                Style="{StaticResource NeoButton}"
                                Content="Clear Balls"
                                Margin="0,10,0,0"
                                Click="Clear_Click"/>
                    </StackPanel>
                </Border>

                <!-- Board -->
                <Border Grid.Column="2"
                        Background="#0B0F16"
                        BorderBrush="{StaticResource Stroke}"
                        BorderThickness="2"
                        CornerRadius="14"
                        Padding="10">

                    <!-- Viewbox scales a NICE big native board to fill the area -->
                    <Viewbox Stretch="Uniform">
                        <!-- Native coordinate space: board + multiplier strip -->
                        <Grid x:Name="NativeRoot" Width="780" Height="420">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>

                            <!-- Board area -->
                            <Grid Grid.Row="0" ClipToBounds="True">
                                <Image x:Name="PegLayerImage"
                                       Width="780" Height="392"
                                       Stretch="Fill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>

                                <Canvas x:Name="BallLayer"
                                        Width="780" Height="392"
                                        ClipToBounds="True"
                                        IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Clean multiplier strip (single source of truth) -->
                            <Border Grid.Row="1"
                                    Background="#0B1220"
                                    BorderBrush="{StaticResource Stroke}"
                                    BorderThickness="2"
                                    CornerRadius="10"
                                    Padding="6,2">
                                <UniformGrid x:Name="BucketGrid" Rows="1"/>
                            </Border>
                        </Grid>
                    </Viewbox>
                </Border>

            </Grid>
        </Border>
    </Grid>
</UserControl>


